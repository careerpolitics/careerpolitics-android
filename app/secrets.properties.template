# secrets.properties.template
# Copy this file to secrets.properties and fill in your actual values.
# NEVER commit secrets.properties to version control.

# Keystore Configuration (for release builds)
keystore.path=release-keystore.jks
keystore.password=YOUR_KEYSTORE_PASSWORD
key.alias=release
key.password=YOUR_KEY_PASSWORD

# Google OAuth (Credential Manager)
google.web.client.id=YOUR_GOOGLE_WEB_CLIENT_ID